---
import { defaultLocale, type Locale } from "../i18n/translations";

const locales: Locale[] = ["en", "da", "ko"];
---

<div
  class="fixed right-4 top-4 z-50 flex items-center gap-0.5 border border-ink/15 bg-canvas/95 px-0.5 py-0.5 shadow-sm backdrop-blur-sm md:right-6 md:top-6"
  role="navigation"
  aria-label="Language"
>
  {
    locales.map((code) => (
      <button
        type="button"
        class="lang-btn px-2.5 py-1.5 font-sans text-[11px] font-medium uppercase tracking-wider text-muted transition hover:text-ink data-[active]:bg-smudge data-[active]:text-ink"
        data-locale={code}
        aria-pressed="false"
      >
        {code}
      </button>
    ))
  }
</div>

<script>
  import { defaultLocale, translations } from "../i18n/translations";

  const STORAGE_KEY = "sofiefribo.locale";

  type Locale = "en" | "da" | "ko";

  type CvBlock = { year: string; items: string[] };

  function setText(selector: string, value: string) {
    document.querySelectorAll<HTMLElement>(selector).forEach((el) => {
      el.textContent = value;
    });
  }

  function setHtml(selector: string, value: string) {
    document.querySelectorAll<HTMLElement>(selector).forEach((el) => {
      el.innerHTML = value;
    });
  }

  function renderCareerAccordion(blocks: CvBlock[]) {
    const root = document.getElementById("career-accordion");
    if (!root) return;

    root.replaceChildren();

    for (const block of blocks) {
      const details = document.createElement("details");
      details.className = "group border-b border-ink/10";

      const summary = document.createElement("summary");
      summary.className =
        "flex cursor-pointer list-none items-center justify-between gap-4 py-5 outline-none [&::-webkit-details-marker]:hidden";

      const yearSpan = document.createElement("span");
      yearSpan.className =
        "font-serif text-lg font-medium tracking-tight text-ink md:text-xl";
      yearSpan.textContent = block.year;

      const chev = document.createElement("span");
      chev.className =
        "inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-ink/15 text-muted transition-transform duration-200 group-open:rotate-180";
      chev.setAttribute("aria-hidden", "true");
      chev.textContent = "↓";

      summary.appendChild(yearSpan);
      summary.appendChild(chev);

      const panel = document.createElement("div");
      panel.className = "border-t border-line bg-smudge/50 px-1 py-5 md:px-3";

      const ul = document.createElement("ul");
      ul.className =
        "list-disc space-y-2.5 pl-5 font-sans text-sm leading-relaxed text-muted md:text-[15px]";
      for (const item of block.items) {
        const li = document.createElement("li");
        li.textContent = item;
        ul.appendChild(li);
      }
      panel.appendChild(ul);

      details.appendChild(summary);
      details.appendChild(panel);
      root.appendChild(details);
    }
  }

  function applyLocale(locale: Locale) {
    const t = translations[locale];
    document.documentElement.lang = locale === "ko" ? "ko" : locale === "da" ? "da" : "en";

    document.title = t.meta.title;
    const md = document.querySelector<HTMLMetaElement>('meta[name="description"]');
    if (md) md.content = t.meta.description;

    setText("[data-i18n='hero.tagline']", t.hero.tagline);
    setText("[data-i18n='hero.name']", t.hero.name);
    setText("[data-i18n='hero.role']", t.hero.role);
    setText("[data-i18n='hero.cta']", t.hero.cta);
    const heroCta = document.querySelector<HTMLAnchorElement>("[data-i18n-attr='hero.cta']");
    if (heroCta) heroCta.setAttribute("aria-label", `${t.hero.cta}. ${t.hero.ctaHint}`);

    setText("[data-i18n='about.title']", t.about.title);
    setText("[data-i18n='about.p1']", t.about.p1);
    setText("[data-i18n='about.p2']", t.about.p2);
    setText("[data-i18n='about.p3']", t.about.p3);

    setText("[data-i18n='career.title']", t.career.title);
    setText("[data-i18n='career.hint']", t.career.hint);
    renderCareerAccordion(t.career.blocks);

    setText("[data-i18n='collaboration.title']", t.collaboration.title);
    setText("[data-i18n='collaboration.role']", t.collaboration.role);
    setText("[data-i18n='collaboration.p1']", t.collaboration.p1);
    setText("[data-i18n='collaboration.p2']", t.collaboration.p2);
    setText("[data-i18n='collaboration.shopifyCta']", t.collaboration.shopifyCta);
    const shop = document.querySelector<HTMLAnchorElement>("[data-i18n-attr='collaboration.shopify']");
    if (shop)
      shop.setAttribute(
        "aria-label",
        `${t.collaboration.shopifyCta}. ${t.collaboration.shopifyHint}`,
      );

    setText("[data-i18n='footer.contactLabel']", t.footer.contactLabel);
    setText("[data-i18n='footer.designed']", t.footer.designed);
    setHtml(
      "[data-i18n='footer.rights']",
      `© ${new Date().getFullYear()} ${t.footer.rights}`,
    );

    const ig = document.querySelector<HTMLAnchorElement>("[data-i18n-attr='footer.instagram']");
    if (ig) ig.setAttribute("aria-label", t.footer.instagramAria);

    const mail = document.querySelector<HTMLAnchorElement>("[data-i18n-attr='footer.mail']");
    if (mail) mail.setAttribute("aria-label", t.footer.mailAria);

    document.querySelectorAll(".lang-btn").forEach((btn) => {
      const code = btn.getAttribute("data-locale") as Locale;
      const on = code === locale;
      btn.setAttribute("aria-pressed", on ? "true" : "false");
      btn.toggleAttribute("data-active", on);
    });

    try {
      localStorage.setItem(STORAGE_KEY, locale);
    } catch {
      /* private mode */
    }
  }

  function readStored(): Locale | null {
    try {
      const v = localStorage.getItem(STORAGE_KEY);
      if (v === "en" || v === "da" || v === "ko") return v;
    } catch {
      /* ignore */
    }
    return null;
  }

  function init() {
    const stored = readStored();
    applyLocale(stored ?? defaultLocale);

    document.querySelectorAll(".lang-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const code = btn.getAttribute("data-locale") as Locale;
        applyLocale(code);
      });
    });
  }

  init();
</script>
