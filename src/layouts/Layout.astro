---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sofie Fribo — Portfolio",
  description = "Illustration on paper — quiet lines and soft contrast.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Noto+Serif+KR:wght@400;600;700&family=Noto+Serif:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      try {
        var k = localStorage.getItem("sofiefribo.locale");
        if (k === "en" || k === "da" || k === "ko")
          document.documentElement.setAttribute("data-user-locale", k);
      } catch (e) {}
    </script>
  </head>
  <body
    class="min-h-screen bg-canvas font-sans text-ink antialiased selection:bg-ink/10 selection:text-ink"
  >
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    background-color: #ffffff;
  }
</style>
